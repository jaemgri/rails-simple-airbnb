<!-- app/views/flats/_form.html.erb -->
<%= simple_form_for(@flat) do |f| %>
  <%= f.input :name %>
  <%= f.input :address %>
  <%= f.input :picture_url, label: "Image URL (Unsplash link)" %> <!-- Added this line -->
  <%= f.input :description, as: :text %>
  <%= f.input :price_per_night, as: :integer %>
  <%= f.input :number_of_guests, as: :integer %>
  <%= f.button :submit, class: 'btn btn-primary' %>
<% end %>
