<!-- Main Backdrop wrapper -->
<div class="w-100 min-vh-100 bg-light pt-5">
  <div class="container">

    <!-- Header & Search Controls -->
    <div class="row mb-4 align-items-center px-2">
      <div class="col-12 col-md-6">
        <h1 class="fw-bold text-dark mb-md-0" style="font-size: 2.5rem;">All our Flats (<%= @flats.count %>)</h1>
      </div>

      <!-- The Search Form -->
      <div class="col-12 col-md-6">
        <%= form_with url: flats_path, method: :get, class: "d-flex gap-2" do |f| %>
          <%= f.text_field :query,
                           value: params[:query],
                           placeholder: "Search for a flat (e.g. garden, tower)...",
                           class: "form-control rounded-0 border-light-subtle py-2 shadow-sm" %>
          <%= f.submit "Search", class: "btn btn-primary rounded-0 px-4 fw-bold shadow-sm" %>
          <% if params[:query].present? %>
            <%= link_to "Clear", flats_path, class: "btn btn-outline-secondary rounded-0 d-flex align-items-center" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Grid View -->
    <div class="row px-2">
      <% if @flats.any? %>
        <% @flats.each do |flat| %>
          <!-- Your existing cards loop logic goes exactly here... -->
          <div class="col-12 col-md-4 mb-4">
            <div class="card h-100 border border-light-subtle shadow-sm bg-white rounded-0">
              <% if flat.picture_url.present? %>
                <img src="<%= flat.picture_url %>" class="card-img-top rounded-0" alt="<%= flat.name %>" style="height: 210px; object-fit: cover;">
              <% else %>
                <img src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&w=600&q=80" class="card-img-top rounded-0" style="height: 210px; object-fit: cover;" alt="Placeholder">
              <% end %>

              <div class="card-body p-4">
                <h3 class="card-title fw-bold text-dark mb-2" style="font-size: 1.35rem; line-height: 1.3; min-height: 3.5rem;">
                  <%= flat.name %>
                </h3>
                <p class="card-text text-secondary small mb-4"><%= flat.address %></p>

                <div class="d-flex align-items-center gap-4 text-secondary mb-2">
                  <span class="d-flex align-items-center gap-2">
                    <i class="fa-solid fa-users fs-5"></i> <strong class="text-dark"><%= flat.number_of_guests %></strong>
                  </span>
                  <span class="d-flex align-items-center gap-2">
                    <i class="fa-solid fa-euro-sign fs-5"></i> <strong class="text-dark"><%= flat.price_per_night %></strong>
                  </span>
                </div>
              </div>

              <div class="card-footer bg-white border-top border-light-subtle p-4 rounded-0 d-flex justify-content-between align-items-center">
                <%= link_to "More info", flat_path(flat), class: "text-primary text-decoration-none" %>
                <div class="d-flex align-items-center gap-3">
                  <%= link_to edit_flat_path(flat), class: "text-warning" do %><i class="fa-solid fa-pen-to-square fs-5"></i><% end %>
                  <%= link_to flat_path(flat), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-danger" do %><i class="fa-solid fa-trash fs-5"></i><% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <!-- Graceful fallback state if search yields 0 results -->
        <div class="col-12 px-2 mt-4 text-center py-5 bg-white border shadow-sm">
          <i class="fa-solid fa-house-crack text-muted mb-3" style="font-size: 3rem;"></i>
          <p class="fs-4 text-secondary">We couldn't find any listings matching "<strong><%= params[:query] %></strong>"</p>
          <%= link_to "View all flats", flats_path, class: "btn btn-primary rounded-0 mt-2 px-4" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
